                  "});\r",
                  "\r",
                  "pm.test(\"Usuário criado com sucesso\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.first_name).to.eql(\"test\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"teste@reqres.in\",\r\n    \"first_name\": \"test\",\r\n    \"last_name\": \"test\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
